import { useCallback, useRef } from 'react'
import { IconRefresh } from './Icons'

type Props = {
  maxLSN: number
  currentLSN: number
  onScrub: (lsn: number) => void
  onRefresh: () => void
}

export function TimelineScrubber({ maxLSN, currentLSN, onScrub, onRefresh }: Props) {
  const trackRef = useRef<HTMLDivElement>(null)
  const isDragging = useRef(false)
  const debounceRef = useRef<ReturnType<typeof setTimeout> | undefined>(undefined)

  const lsnFromMouseEvent = (e: { clientX: number }) => {
    const track = trackRef.current
    if (!track) return currentLSN
    const rect = track.getBoundingClientRect()
    const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width))
    return Math.max(1, Math.round(pct * maxLSN))
  }

  const debouncedScrub = useCallback(
    (lsn: number) => {
      if (debounceRef.current) clearTimeout(debounceRef.current)
      debounceRef.current = setTimeout(() => onScrub(lsn), 150)
    },
    [onScrub],
  )

  const handleMouseDown = (e: React.MouseEvent) => {
    isDragging.current = true
    const lsn = lsnFromMouseEvent(e)
    debouncedScrub(lsn)

    const handleMouseMove = (ev: MouseEvent) => {
      if (!isDragging.current) return
      const l = lsnFromMouseEvent(ev)
      debouncedScrub(l)
    }

    const handleMouseUp = () => {
      isDragging.current = false
      document.removeEventListener('mousemove', handleMouseMove)
      document.removeEventListener('mouseup', handleMouseUp)
    }

    document.addEventListener('mousemove', handleMouseMove)
    document.addEventListener('mouseup', handleMouseUp)
  }

  const pct = maxLSN > 0 ? (currentLSN / maxLSN) * 100 : 0
  const ticks = generateTicks(maxLSN)

  return (
    <div className="timeline-scrubber">
      <div className="timeline-label mono">
        LSN {currentLSN} / {maxLSN}
      </div>
      <div className="timeline-track" ref={trackRef} onMouseDown={handleMouseDown}>
        <div className="timeline-fill" style={{ width: `${pct}%` }} />
        <div className="timeline-handle" style={{ left: `${pct}%` }} />
        {ticks.map((tick) => (
          <div
            key={tick}
            className="timeline-tick"
            style={{ left: `${(tick / maxLSN) * 100}%` }}
          >
            <span className="timeline-tick-label">{tick}</span>
          </div>
        ))}
      </div>
      <button className="icon-btn" onClick={onRefresh} title="Refresh max LSN">
        <IconRefresh />
      </button>
    </div>
  )
}

function generateTicks(max: number): number[] {
  if (max <= 0) return []
  const count = Math.min(5, max)
  const step = Math.max(1, Math.floor(max / count))
  const ticks: number[] = []
  for (let i = step; i <= max; i += step) {
    ticks.push(i)
  }
  if (ticks[ticks.length - 1] !== max) ticks.push(max)
  return ticks
}
